{
  "name": "blendtune",
  "version": "0.1.4",
  "private": true,
  "scripts": {
    "build": "vite build --config main/apps/web/vite.config.ts",
    "start": "node node_modules/tsx/dist/cli.mjs main/apps/server/src/main.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:watch": "eslint . --ext .js,.jsx,.ts,.tsx --watch",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:dry": "tsx scripts/migrate.ts --dry-run",
    "db:status": "tsx scripts/db-status.ts",
    "dev:api": "tsx watch main/apps/server/src/main.ts",
    "start:api": "tsx main/apps/server/src/main.ts",
    "dev:web": "vite --config main/apps/web/vite.config.ts",
    "build:web": "vite build --config main/apps/web/vite.config.ts",
    "preview:web": "vite preview --config main/apps/web/vite.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "@fortawesome/fontawesome-common-types": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/forms": "^0.5.11",
    "argon2": "^0.44.0",
    "bcrypt": "^5.1.1",
    "fastify": "^5.10.0",
    "lodash": "^4.18.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.13",
    "postgres": "^3.4.4",
    "rc-slider": "^11.1.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "redux": "^5.0.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.20.0",
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.62.1",
    "vite": "^6.4.3"
  },
  "pnpm": {
    "overrides": {
      "browserslist": "4.28.4",
      "caniuse-lite": "1.0.30001800",
      "@typescript-eslint/types": "8.62.1",
      "@typescript-eslint/tsconfig-utils": "8.62.1"
    }
  }
}
