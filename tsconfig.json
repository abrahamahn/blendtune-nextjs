{
  "compilerOptions": {
    "target": "es6",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": "./",
    "paths": {
      /* bslt-shaped packages under main/ (M1 migration) */
      "@/shared/*": [
        "main/shared/src/*"
      ],
      "@types/*": [
        "./main/shared/src/types/*"
      ],
      "@client/*": [
        "main/apps/web/src/client/*"
      ],
      "@router/*": [
        "main/client/react/src/router/*"
      ],
      "@router": [
        "main/client/react/src/router"
      ],
      "@server/db": [
        "main/server/db/src"
      ],
      "@server/db/*": [
        "main/server/db/src/*"
      ],
      "@server/core/*": [
        "main/server/core/src/*"
      ],
      "@server/storage": [
        "main/server/storage/src"
      ],
      "@server/storage/*": [
        "main/server/storage/src/*"
      ],
      "@server/media": [
        "main/server/media/src"
      ],
      "@server/media/*": [
        "main/server/media/src/*"
      ],
      "@server/system/*": [
        "main/server/system/src/*"
      ],
      "@shared/*": [
        "main/shared/src/*"
      ],
      /* Feature paths */
      "@features/*": [
        "main/apps/web/src/client/features/*"
      ],
      "@auth/*": [
        "main/apps/web/src/client/features/auth/*"
      ],
      "@layout/*": [
        "main/apps/web/src/client/features/layout/*"
      ],
      "@player/*": [
        "main/apps/web/src/client/features/player/*"
      ],
      "@sounds/*": [
        "main/apps/web/src/client/features/sounds/*"
      ],
      "@home/*": [
        "main/apps/web/src/client/features/home/*"
      ],
      "@tracks/*": [
        "main/apps/web/src/client/features/tracks/*"
      ],
      /* Sounds feature subpaths */
      "@filters/*": [
        "main/apps/web/src/client/features/sounds/filters/*"
      ],
      "@category/*": [
        "main/apps/web/src/client/features/sounds/category/*"
      ],
      "@search/*": [
        "main/apps/web/src/client/features/sounds/search/*"
      ],
      "@visualizer/*": [
        "main/apps/web/src/client/features/sounds/visualizer/*"
      ],
      "@keywords*": [
        "main/apps/web/src/client/features/sounds/tracks/keywords/*"
      ],
      "@catalog/*": [
        "main/apps/web/src/client/features/sounds/catalog/*"
      ],
      /* Layout feature subpaths */
      "@header/*": [
        "main/apps/web/src/client/features/layout/header/*"
      ],
      "@footer/*": [
        "main/apps/web/src/client/features/layout/footer/*"
      ],
      "@leftbar/*": [
        "main/apps/web/src/client/features/layout/leftbar/*"
      ],
      "@rightbar/*": [
        "main/apps/web/src/client/features/layout/rightbar/*"
      ],
      /* Core and shared paths */
      "@core/*": [
        "main/apps/web/src/client/core/*"
      ],
      "@components/*": [
        "main/apps/web/src/client/shared/components/*"
      ],
      "@utils/*": [
        "main/apps/web/src/client/shared/utils/*"
      ],
      "@hooks/*": [
        "main/apps/web/src/client/shared/hooks/*"
      ],
      "@constants/*": [
        "main/apps/web/src/client/shared/constants/*"
      ],
      "@styles/*": [
        "main/apps/web/src/client/shared/styles/*"
      ],
      /* Core subpaths */
      "@providers/*": [
        "main/apps/web/src/client/core/providers/*"
      ],
      "@store/*": [
        "main/apps/web/src/client/core/store/*"
      ],
      "@context/*": [
        "main/apps/web/src/client/core/context/*"
      ],
      "@services/*": [
        "main/apps/web/src/client/core/services/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
